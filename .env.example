# ============================================================
# LNAYCRM — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Supabase (EXTERNE — ne pas toucher la structure) ─────────
DATABASE_URL="postgresql://postgres.VOTRE_REF:MOT_DE_PASSE@aws-1-eu-central-2.pooler.supabase.com:5432/postgres"

# ── JWT (CHANGER IMPÉRATIVEMENT en production) ───────────────
JWT_SECRET=change_me_to_64_random_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_64_random_chars_xxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────────────────────
# (géré automatiquement par Docker — ne pas changer si Docker)
REDIS_URL=redis://localhost:6379

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=lnaycrm_minio
MINIO_ROOT_PASSWORD=minio_secret_2024
# URL publique pour téléchargement (via Nginx ou direct)
STORAGE_PUBLIC_URL=http://localhost:9000

# ── Ollama ───────────────────────────────────────────────────
# gemma3:1b = léger (~815MB RAM) | llama3.2:3b = meilleur (~2GB RAM)
OLLAMA_MODEL=gemma3:1b

# ── Asterisk AMI ─────────────────────────────────────────────
AMI_SECRET=AMI_LNAYCRM_SECRET_2024!

# ── Frontend ─────────────────────────────────────────────────
# URL du backend vue depuis le navigateur (client-side)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Via Nginx (recommandé) :
# NEXT_PUBLIC_BACKEND_URL=http://localhost
# NEXT_PUBLIC_WS_URL=http://localhost

# Via Cloudflare Tunnel (production) :
# NEXT_PUBLIC_BACKEND_URL=https://api.lnaycrm.com
# NEXT_PUBLIC_WS_URL=https://api.lnaycrm.com

# CORS — origins autorisées par le backend
FRONTEND_URL=http://localhost:3000
FRONTEND_CF_URL=

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
