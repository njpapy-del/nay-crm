# ============================================================
# LNAYCRM - Environment Variables Example
# Copy this file to .env and fill in the values
# ============================================================

# ---- Node ----
NODE_ENV=development

# ---- Database ----
DATABASE_URL="postgresql://lnaycrm:lnaycrm_password@localhost:5432/lnaycrm_db?schema=public"
POSTGRES_USER=lnaycrm
POSTGRES_PASSWORD=lnaycrm_password
POSTGRES_DB=lnaycrm_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=change_me_to_a_very_long_random_secret_string_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_secret_string_at_least_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- Backend ----
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# ---- Frontend ----
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
FRONTEND_PORT=3000

# ---- Asterisk AMI ----
ASTERISK_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=lnaycrm
ASTERISK_AMI_SECRET=lnaycrm_ami_secret
ASTERISK_ARI_URL=http://127.0.0.1:8088
ASTERISK_ARI_USER=lnaycrm_ari
ASTERISK_ARI_PASSWORD=lnaycrm_ari_secret

# ---- SIP ----
SIP_SERVER=sip.example.com
SIP_WEBSOCKET_URL=wss://sip.example.com:7443/ws
SIP_REALM=example.com

# ---- Storage (enregistrements) ----
RECORDINGS_PATH=/var/spool/asterisk/monitor
RECORDINGS_URL=http://localhost:3001/recordings

# ---- Email (notifications) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password
SMTP_FROM="LNAYCRM <noreply@example.com>"

# ---- Misc ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100
LOG_LEVEL=debug
