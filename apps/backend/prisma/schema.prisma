  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, campaignId])
  @@index([expiresAt])
  @@index([callerNumber])
  @@map("recordings")
}

// ─────────────────────────────────────────
// CallLog (Journal appels qualifié)
// ─────────────────────────────────────────

model CallLog {
  id            String            @id @default(cuid())
  tenantId      String
  callId        String            @unique
  agentId       String?
  campaignId    String?
  callerNumber  String
  calleeNumber  String
  durationSec   Int               @default(0)
  qualification CallQualification?
  status        CallLogStatus     @default(PENDING)
  notes         String?
  agentNotes    String?
  rdvAt         DateTime?         // pour qualification APPOINTMENT
  callbackAt    DateTime?         // pour qualification CALLBACK
  scriptResponseId String?        // lien vers réponses script
  qualifiedAt          DateTime?
  reviewedAt           DateTime?
  postCallDurationSec  Int?
  qualificationRequired Boolean  @default(false)
  motifRefus           String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  call     Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  agent    User?     @relation("CallLogAgent", fields: [agentId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
