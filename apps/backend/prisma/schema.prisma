// ============================================================
// LNAYCRM - Prisma Schema
// Multi-tenant CRM + Call Center + Gestion commerciale
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  AGENT
  QUALITY
  QUALITY_SUPERVISOR
  HR
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  DNC
}

enum ClientQualification {
  RDV
  FACTURE
  VENDU
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── SaaS enums ──────────────────────────────────────────────────────────────

enum PlanCode {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_RESET
  TOKEN_REFRESH
  FORCE_LOGOUT
  ACCOUNT_LOCKED
  PERMISSION_DENIED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum CallDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CallStatus {
  RINGING
  ANSWERED
  BUSY
  NO_ANSWER
  FAILED
  CANCELLED
}

enum CallDisposition {
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  WRONG_NUMBER
  VOICEMAIL
  DNC
  SALE
}

enum AgentAvailability {
  OFFLINE
  AVAILABLE
  RINGING
  IN_CALL
  WRAP_UP
  PAUSED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignType {
  EMISSION
  RECEPTION
  MIXTE
}

enum NumberRotationMode {
  MANUAL
  ROUND_ROBIN
  RANDOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  DONE
}

enum RecordingFormat {
  WAV
  MP3
  OGG
}

enum CallQualification {
  SALE
  APPOINTMENT
  NOT_INTERESTED
  CALLBACK
  WRONG_NUMBER
  VOICEMAIL
  DNC
  NRP
  UNREACHABLE
  REFUSAL
  OUT_OF_TARGET
  OTHER
}

enum CallLogStatus {
  PENDING
  QUALIFIED
  REVIEWED
}

enum AgentStatusType {
  AVAILABLE
  IN_CALL
  DEBRIEF
  LUNCH_BREAK
  COFFEE_BREAK
  TOILET_BREAK
  TRAINING
  OFFLINE
}

enum PlanningEventType {
  BREAK
  TOILET
  LUNCH
  TRAINING
  ABSENCE
  MEETING
}

enum PlanningStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ContactListStatus {
  ACTIVE
  ARCHIVED
  PROCESSING
}

enum ContactStatus {
  NEW
  CALLED
  CALLBACK
  REFUSED
  OUT_OF_TARGET
  RECYCLED
  CONVERTED
  DNC
}

enum BlacklistScope {
  GLOBAL
  TENANT
  CAMPAIGN
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────

model Tenant {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  plan        TenantPlan @default(FREE)
  subdomain   String?    @unique
  domain      String?    @unique
  logoUrl     String?
  address     String?
  phone       String?
  isActive    Boolean    @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users            User[]
  calls            Call[]
  agentSessions    AgentSession[]
  clients          Client[]
  products         Product[]
  quotes           Quote[]
  invoices         Invoice[]
  campaigns        Campaign[]
  leads            Lead[]
  appointments     Appointment[]
  notifications    Notification[]
  contactLists     ContactList[]
  contacts         Contact[]
  importHistories  ImportHistory[]
  blacklists       Blacklist[]
  blacklistEntries BlacklistEntry[]
  recyclingLogs    RecyclingLog[]
  recordings       Recording[]
  callLogs         CallLog[]
  recordingLogs    RecordingAccessLog[]
  sales            Sale[]
  qualifications   Qualification[]
  userSessions     UserSession[]
  activityLogs     ActivityLog[]
  kpiDaily         KpiDaily[]
  kpiMonthly       KpiMonthly[]
  reports          Report[]
  alertRules       AlertRule[]
  subscription     Subscription?
  securityLogs     SecurityLog[]
  reminders        Reminder[]
  scripts          Script[]
  scriptResponses  ScriptResponse[]
  callNotes             CallNote[]
  agentStatusLogs       AgentStatusLog[]
  agentPlannings        AgentPlanning[]
  agentPlanningRequests AgentPlanningRequest[]
  aiJobs                AiJob[]
  aiUsage               AiUsage[]
  campaignCriteria      CampaignCriteria[]
  appointmentResponses  AppointmentResponse[]
  appointmentScores     AppointmentScore[]
  internalChannels      InternalChannel[]
  internalMessages      InternalMessage[]
  qualityGrids          QualityGrid[]
  qualityEvaluations    QualityEvaluation[]
  appointmentQualifications AppointmentQualification[]
  qualityActions        QualityAction[]
  hrRequests            HrRequest[]
  hrAttendances         HrAttendance[]
  campaignNumbers       CampaignNumber[]
  supervisionLogs       CallSupervisionLog[]
  menuPermissions       RoleMenuPermission[]

  @@index([slug])
  @@map("tenants")
}

// ─────────────────────────────────────────
// Permissions menu par rôle
// ─────────────────────────────────────────

model RoleMenuPermission {
  id       String @id @default(cuid())
  tenantId String
  role     String          // 'MANAGER' | 'AGENT' | 'QUALITY' | 'QUALITY_SUPERVISOR' | 'HR'
  navKey   String          // clé du nav item (ex: 'quotes', 'invoices', 'reports')
  visible  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, navKey])
  @@index([tenantId, role])
  @@map("role_menu_permissions")
}

// ─────────────────────────────────────────
// User
// ─────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  password    String
  firstName   String
  lastName    String
  role        Role      @default(AGENT)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedClients     Client[]         @relation("AssignedAgent")
  qualifiedClients    Client[]         @relation("QualifiedBy")
  refreshTokens       RefreshToken[]
  quotes              Quote[]          @relation("QuoteCreator")
  invoices            Invoice[]        @relation("InvoiceCreator")
  calls               Call[]           @relation("AgentCalls")
  agentSession        AgentSession?
  createdCampaigns    Campaign[]       @relation("CampaignCreator")
  campaignAgents      CampaignAgent[]
  assignedLeads       Lead[]           @relation("LeadAssignee")
  agentAppointments   Appointment[]    @relation("AppointmentAgent")
  notifications       Notification[]
  createdLists        ContactList[]        @relation("ListCreator")
  importHistories     ImportHistory[]      @relation("ImportCreator")
  createdBlacklists   Blacklist[]          @relation("BlacklistCreator")
  blacklistEntries    BlacklistEntry[]     @relation("BlacklistEntryAdder")
  recyclingLogs       RecyclingLog[]       @relation("RecyclingAgent")
  recordingAccessLogs RecordingAccessLog[] @relation("RecordingAccessor")
  callLogs            CallLog[]            @relation("CallLogAgent")
  recordings          Recording[]          @relation("AgentRecordings")
  sales               Sale[]               @relation("AgentSales")
  saleLogs            SaleLog[]            @relation("SaleLogAuditor")
  userSessions        UserSession[]
  activityLogs        ActivityLog[]
  createdReports      Report[]     @relation("ReportCreator")
  reminders           Reminder[]
  createdScripts      Script[]     @relation("ScriptCreator")
  scriptResponses     ScriptResponse[] @relation("AgentScriptResponses")
  callNotes           CallNote[]   @relation("AgentCallNotes")
  statusLogs          AgentStatusLog[]        @relation("AgentStatusLogs")
  agentPlannings      AgentPlanning[]         @relation("AgentPlannings")
  createdPlannings    AgentPlanning[]         @relation("PlanningCreator")
  planningRequests    AgentPlanningRequest[]  @relation("AgentPlanningRequests")
  reviewedRequests    AgentPlanningRequest[]  @relation("PlanningReviewer")
  aiJobs              AiJob[]                 @relation("UserAiJobs")
  scoreReviews        AppointmentScore[]      @relation("ScoreReviewer")
  internalMessages    InternalMessage[]       @relation("UserMessages")
  createdChannels     InternalChannel[]       @relation("ChannelCreator")
  evaluatedByMe       QualityEvaluation[]     @relation("Evaluator")
  myEvaluations       QualityEvaluation[]     @relation("EvaluatedAgent")
  qualifiedRdv        AppointmentQualification[] @relation("QualifiedBy")
  qualityActionsGiven QualityAction[]         @relation("ActionCreator")
  qualityActionsReceived QualityAction[]      @relation("ActionTarget")
  hrRequestsSubmitted HrRequest[]             @relation("HrRequestAgent")
  hrRequestsReviewed  HrRequest[]             @relation("HrReviewer")
  hrAttendances             HrAttendance[]          @relation("AttendanceAgent")
  supervisionLogsAsSupervisor CallSupervisionLog[]  @relation("SupervisionSupervisor")
  supervisionLogsAsAgent      CallSupervisionLog[]  @relation("SupervisionAgent")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

// ─────────────────────────────────────────
// RefreshToken
// ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// Client
// ─────────────────────────────────────────

model Client {
  id              String       @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String?
  phone           String
  company         String?
  status          ClientStatus        @default(PROSPECT)
  notes           String?
  address         String?
  postalCode      String?
  qualification   ClientQualification?
  qualifiedAt     DateTime?
  qualifiedById   String?
  assignedAgentId String?
  customData      Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedAgent User?         @relation("AssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  qualifiedBy   User?         @relation("QualifiedBy", fields: [qualifiedById], references: [id], onDelete: SetNull)
  quotes        Quote[]
  invoices      Invoice[]
  appointments  Appointment[]
  calls         Call[]
  sales         Sale[]
  reminders     Reminder[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, qualification])
  @@index([tenantId, assignedAgentId])
  @@map("clients")
}

// ─────────────────────────────────────────
// Product (catalogue)
// ─────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  unitPrice   Float    @default(0)
  unit        String   @default("unité")
  taxRate     Float    @default(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteLines QuoteLine[]

  @@index([tenantId])
  @@map("products")
}

// ─────────────────────────────────────────
// Quote (Devis)
// ─────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  tenantId    String
  clientId    String
  createdById String
  number      String
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  notes       String?
  subtotal    Float       @default(0)
  taxAmount   Float       @default(0)
  total       Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id])
  createdBy User       @relation("QuoteCreator", fields: [createdById], references: [id])
  lines     QuoteLine[]
  invoice   Invoice?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quotes")
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  taxRate     Float    @default(20)
  total       Float    @default(0)
  position    Int      @default(0)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@map("quote_lines")
}

// ─────────────────────────────────────────
// Invoice (Facture)
// ─────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  clientId    String
  quoteId     String?       @unique
  createdById String
  number      String
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime?
  notes       String?
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  total       Float         @default(0)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client        @relation(fields: [clientId], references: [id])
  quote     Quote?        @relation(fields: [quoteId], references: [id])
  createdBy User          @relation("InvoiceCreator", fields: [createdById], references: [id])
  lines     InvoiceLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  taxRate     Float   @default(20)
  total       Float   @default(0)
  position    Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ─────────────────────────────────────────
// Campaign (Campagne)
// ─────────────────────────────────────────

model Campaign {
  id               String             @id @default(cuid())
  tenantId         String
  createdById      String
  name             String
  description      String?
  status           CampaignStatus     @default(DRAFT)
  type             CampaignType       @default(EMISSION)
  callerIdRotation NumberRotationMode @default(MANUAL)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User             @relation("CampaignCreator", fields: [createdById], references: [id])
  agents        CampaignAgent[]
  leads         Lead[]
  appointments  Appointment[]
  contactLists  ContactList[]    @relation("CampaignContactLists")
  blacklists    Blacklist[]      @relation("CampaignBlacklists")
  recordings    Recording[]
  callLogs      CallLog[]
  sales         Sale[]
  settings      CampaignSettings?
  qualifications Qualification[]
  scripts        Script[]
  criteria      CampaignCriteria?
  agentSessions AgentSession[]
  qualityGrids  QualityGrid[]
  numbers       CampaignNumber[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("campaigns")
}

model CampaignAgent {
  id         String   @id @default(cuid())
  campaignId String
  agentId    String
  assignedAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agent    User     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([campaignId, agentId])
  @@map("campaign_agents")
}

// ─────────────────────────────────────────
// CampaignNumber — Numéros sortants
// ─────────────────────────────────────────

model CampaignNumber {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  number     String
  label      String?
  isActive   Boolean  @default(false)
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, number])
  @@index([tenantId])
  @@index([campaignId])
  @@map("campaign_numbers")
}

// ─────────────────────────────────────────
// Lead
// ─────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  tenantId     String
  campaignId   String
  assignedToId String?
  firstName    String
  lastName     String
  email        String?
  phone        String?
  company      String?
  status       LeadStatus @default(NEW)
  notes        String?
  customData   Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignedTo   User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  calls        Call[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([tenantId, status])
  @@map("leads")
}

// ─────────────────────────────────────────
// Appointment (Rendez-vous)
// ─────────────────────────────────────────

model Appointment {
  id          String            @id @default(cuid())
  tenantId    String
  agentId     String
  leadId      String?
  campaignId  String?
  clientId    String?
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent     User                 @relation("AppointmentAgent", fields: [agentId], references: [id])
  lead      Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign  Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  client    Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  responses        AppointmentResponse[]
  score            AppointmentScore?
  sale             Sale?
  qaQualification  AppointmentQualification?

  @@index([tenantId])
  @@index([agentId])
  @@index([tenantId, startAt])
  @@map("appointments")
}

// ─────────────────────────────────────────
// Notification
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─────────────────────────────────────────
// Call (Historique appels)
// ─────────────────────────────────────────

model Call {
  id            String        @id @default(cuid())
  tenantId      String
  agentId       String?
  clientId      String?
  leadId        String?
  direction     CallDirection
  status        CallStatus
  callerNumber  String
  calleeNumber  String
  asteriskId    String?
  duration      Int?
  recordingUrl  String?
  notes         String?
  disposition   CallDisposition?
  startedAt     DateTime      @default(now())
  answeredAt    DateTime?
  endedAt       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent     User?      @relation("AgentCalls", fields: [agentId], references: [id], onDelete: SetNull)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead      Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  recording Recording?
  callLog   CallLog?
  sale      Sale?

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@index([asteriskId])
  @@map("calls")
}

// ─────────────────────────────────────────
// AgentSession (état temps réel agent)
// ─────────────────────────────────────────

model AgentSession {
  id            String            @id @default(cuid())
  tenantId      String
  agentId       String            @unique
  availability  AgentAvailability @default(OFFLINE)
  extension     String
  currentCallId String?
  campaignId    String?
  pauseReason   String?
  loginAt       DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  pendingQualificationCallLogId String?  // non-null = qualification requise avant prochain appel

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent    User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, availability])
  @@map("agent_sessions")
}

// ─────────────────────────────────────────
// ContactList (Liste de contacts)
// ─────────────────────────────────────────

model ContactList {
  id            String            @id @default(cuid())
  tenantId      String
  campaignId    String?
  createdById   String
  name          String
  source        String?
  description   String?
  status        ContactListStatus @default(ACTIVE)
  isActive      Boolean           @default(true)
  totalContacts Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign  Campaign?       @relation("CampaignContactLists", fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User            @relation("ListCreator", fields: [createdById], references: [id])
  contacts  Contact[]
  imports   ImportHistory[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("contact_lists")
}

// ─────────────────────────────────────────
// Contact
// ─────────────────────────────────────────

model Contact {
  id            String        @id @default(cuid())
  tenantId      String
  listId        String
  firstName     String?
  lastName      String?
  phone         String
  email         String?
  company       String?
  department    String?
  postalCode    String?
  status        ContactStatus @default(NEW)
  customData    Json?
  tags          String[]
  attemptCount  Int           @default(0)
  lastCalledAt  DateTime?
  nextCallAt    DateTime?
  notes         String?
  isBlacklisted Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  list        ContactList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  recycleLogs RecyclingLog[]

  @@index([tenantId])
  @@index([listId])
  @@index([tenantId, status])
  @@index([phone])
  @@index([department])
  @@map("contacts")
}

// ─────────────────────────────────────────
// ImportHistory
// ─────────────────────────────────────────

model ImportHistory {
  id           String       @id @default(cuid())
  tenantId     String
  listId       String
  createdById  String
  fileName     String
  status       ImportStatus @default(PENDING)
  totalRows    Int          @default(0)
  importedRows Int          @default(0)
  skippedRows  Int          @default(0)
  errorRows    Int          @default(0)
  duplicates   Int          @default(0)
  errors       Json?
  columnMap    Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  list      ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy User        @relation("ImportCreator", fields: [createdById], references: [id])

