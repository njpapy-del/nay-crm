  @@index([contactId])
  @@map("recycling_logs")
}

// ─────────────────────────────────────────
// Recording (Enregistrement appel)
// ─────────────────────────────────────────

model Recording {
  id            String          @id @default(cuid())
  tenantId      String
  callId        String          @unique
  agentId       String?
  campaignId    String?
  fileName      String
  filePath      String
  fileSize      Int?
  format        RecordingFormat @default(WAV)
  durationSec   Int             @default(0)
  callerNumber  String
  calleeNumber  String
  asteriskId    String?
  retentionDays Int             @default(60)
  expiresAt     DateTime
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  call       Call                 @relation(fields: [callId], references: [id], onDelete: Cascade)
  agent      User?                @relation("AgentRecordings", fields: [agentId], references: [id], onDelete: SetNull)
  campaign   Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
