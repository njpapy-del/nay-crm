  @@index([tenantId])
  @@map("call_notes")
}

// ─────────────────────────────────────────
// RecordingAccessLog (Audit accès)
// ─────────────────────────────────────────

model RecordingAccessLog {
  id          String   @id @default(cuid())
  tenantId    String
  recordingId String
  userId      String
  action      String   // play | download | delete
  ip          String?
  createdAt   DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  user      User      @relation("RecordingAccessor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, recordingId])
  @@index([userId])
  @@map("recording_access_logs")
}

// ─────────────────────────────────────────
// SaleStatus
// ─────────────────────────────────────────

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum CriteriaFieldType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
}

enum AppointmentQualificationStatus {
  PENDING
  OK
  KO
  HCC
  HC
}

enum DialerMode {
  MANUAL
  PROGRESSIVE
  PREDICTIVE
  PREVIEW
}

// ─────────────────────────────────────────
// Sale (Vente)
// ─────────────────────────────────────────

model Sale {
  id            String            @id @default(cuid())
  tenantId      String
  agentId       String
  clientId      String?
  campaignId    String?
  callId        String?           @unique
  appointmentId String?           @unique
  status        SaleStatus        @default(PENDING)
  amount        Decimal           @db.Decimal(10, 2)
  qualification CallQualification @default(SALE)
  notes         String?
  closedAt      DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent       User        @relation("AgentSales", fields: [agentId], references: [id])
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  campaign    Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  call        Call?       @relation(fields: [callId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  logs        SaleLog[]

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@index([tenantId, campaignId])
  @@index([tenantId, createdAt])
  @@map("sales")
}

// ─────────────────────────────────────────
// SaleLog (Audit ventes)
// ─────────────────────────────────────────

model SaleLog {
  id        String   @id @default(cuid())
  saleId    String
  userId    String
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user User @relation("SaleLogAuditor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_logs")
}

// ─────────────────────────────────────────
// CampaignSettings (Config. dialer par campagne)
// ─────────────────────────────────────────

model CampaignSettings {
  id                   String     @id @default(cuid())
  campaignId           String     @unique
  dialerMode           DialerMode @default(PROGRESSIVE)
  dialerSpeed          Int        @default(1)
  maxSimultaneousCalls Int        @default(1)
  agentRatio           Float      @default(1.0)
  maxAttempts          Int        @default(3)
  retryDelayMin        Int        @default(60)
  wrapUpTimeSec        Int        @default(30)
  enableRecording      Boolean    @default(true)
  enableDnc            Boolean    @default(true)
  customQualifEnabled  Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_settings")
}

// ─────────────────────────────────────────
// Qualification (Qualifications custom par campagne)
// ─────────────────────────────────────────

model Qualification {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String?
  label      String
  code       String
  color      String   @default("#6b7280")
  isPositive Boolean  @default(false)
  position   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([campaignId])
  @@map("qualifications")
}

// ─────────────────────────────────────────
// UserSession (Sessions connectées)
// ─────────────────────────────────────────

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  ip         String?
  userAgent  String?
  token      String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("user_sessions")
}

// ─────────────────────────────────────────
// ActivityLog (Journal d'activité)
// ─────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  action     String
  module     String
  entityId   String?
  entityType String?
  meta       Json?
  ip         String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, module])
  @@index([tenantId, createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────
// KpiDaily (KPIs agrégés par jour)
// ─────────────────────────────────────────

model KpiDaily {
  id                String   @id @default(cuid())
  tenantId          String
  agentId           String?
  campaignId        String?
  date              DateTime @db.Date
  // Appels
  totalCalls        Int      @default(0)
  answeredCalls     Int      @default(0)
  missedCalls       Int      @default(0)
  totalDurationSec  Int      @default(0)
  // RDV
  appointmentsSet   Int      @default(0)
  appointmentsValid Int      @default(0)
  appointmentsCancelled Int  @default(0)
  // Qualifications
  sales             Int      @default(0)
  hcCount           Int      @default(0)
  callbackCount     Int      @default(0)
  dncCount          Int      @default(0)
  // CA
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  // KPIs calculés
  ttr               Float    @default(0)   // Taux Transformation %
  tpr               Float    @default(0)   // Taux Production (RDV/jour)
  tauxHc            Float    @default(0)   // Taux HC %
  tauxContact       Float    @default(0)   // Taux Contact %
  tauxNonReponse    Float    @default(0)   // Taux Non-Réponse %
  tauAnnulation     Float    @default(0)   // Taux Annulation %
  avgCallDurationSec Float   @default(0)   // Durée moyenne appel
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, agentId, campaignId, date])
  @@index([tenantId, date])
  @@index([tenantId, agentId, date])
  @@index([tenantId, campaignId, date])
  @@map("kpi_daily")
}

// ─────────────────────────────────────────
// KpiMonthly (KPIs agrégés par mois)
// ─────────────────────────────────────────

model KpiMonthly {
  id                String   @id @default(cuid())
  tenantId          String
  agentId           String?
  campaignId        String?
  year              Int
  month             Int      // 1-12
  totalCalls        Int      @default(0)
  answeredCalls     Int      @default(0)
  appointmentsSet   Int      @default(0)
  appointmentsValid Int      @default(0)
  sales             Int      @default(0)
  hcCount           Int      @default(0)
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  ttr               Float    @default(0)
  tpr               Float    @default(0)
  tauxHc            Float    @default(0)
  avgCallDurationSec Float   @default(0)
  workingDays       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, agentId, campaignId, year, month])
  @@index([tenantId, year, month])
  @@map("kpi_monthly")
}

// ─────────────────────────────────────────
// Report (Rapports sauvegardés)
// ─────────────────────────────────────────

model Report {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String
  name        String
  description String?
  type        String   @default("CUSTOM")  // CUSTOM | PRESET
  config      Json                          // filtres, colonnes, groupBy
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ReportCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@map("reports")
}

// ─────────────────────────────────────────
// AlertRule (Alertes KPI)
// ─────────────────────────────────────────

model AlertRule {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  metric     String   // ttr | tauxHc | tauAnnulation | avgCallDuration
  operator   String   // lt | gt | lte | gte
  threshold  Float
  agentId    String?
  campaignId String?
  isActive   Boolean  @default(true)
  lastFiredAt DateTime?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("alert_rules")
}

// ─────────────────────────────────────────
// SaaS — Plans
// ─────────────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  code        PlanCode @unique
  name        String
  description String?
  priceMonthly Float   @default(0)
  priceYearly  Float   @default(0)
  maxAgents   Int      @default(5)
  maxCalls    Int      @default(1000)   // per month
  maxStorage  Int      @default(5120)   // MB
  modules     String[]                  // allowed module slugs
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────
// SaaS — Subscriptions
// ─────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  stripeCustomerId   String?
  stripeSubId        String?
  stripeInvoiceId    String?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan    Plan   @relation(fields: [planId], references: [id])
  billingInvoices BillingInvoice[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────
// SaaS — Billing Invoices
// ─────────────────────────────────────────

model BillingInvoice {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String   @default("EUR")
  status         String   @default("DRAFT") // DRAFT | PAID | FAILED
  stripeInvoiceId String?
  paidAt         DateTime?
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("billing_invoices")
}

// ─────────────────────────────────────────
// SaaS — Security Logs
// ─────────────────────────────────────────

model SecurityLog {
  id        String            @id @default(cuid())
  tenantId  String?
  userId    String?
  event     SecurityEventType
  ip        String?
  userAgent String?
  details   Json?
  createdAt DateTime          @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("security_logs")
}

// ─────────────────────────────────────────
// Chatbot — Messages IA
// ─────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String   // 'user' | 'assistant' | 'system'
  content   String   @db.Text
  metadata  Json?    // intent, actions exécutées, etc.
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────
// Chatbot — Rappels agents
// ─────────────────────────────────────────

model Reminder {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  clientId    String?
  title       String
  description String?
  dueAt       DateTime
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  snoozedTo   DateTime?
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId])
  @@index([dueAt])
  @@index([isDone])
  @@map("reminders")
}

// ─────────────────────────────────────────
// Scripts dynamiques
// ─────────────────────────────────────────

enum ScriptFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  RADIO
  CHECKBOX
}

model Script {
  id          String   @id @default(cuid())
  tenantId    String
  campaignId  String?
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User      @relation("ScriptCreator", fields: [createdById], references: [id])
  fields    ScriptField[]
  responses ScriptResponse[]

  @@index([tenantId])
  @@index([tenantId, campaignId])
  @@map("scripts")
}

model ScriptField {
  id           String          @id @default(cuid())
  scriptId     String
  label        String
  type         ScriptFieldType
  required     Boolean         @default(false)
  order        Int             @default(0)
  options      Json?           // string[] pour SELECT/RADIO/CHECKBOX
  conditions   Json?           // [{ ifFieldId, ifValue, action: 'show'|'hide' }]
  placeholder  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  values ScriptResponseValue[]

  @@index([scriptId])
  @@index([scriptId, order])
  @@map("script_fields")
}

model ScriptResponse {
  id         String   @id @default(cuid())
  tenantId   String
  scriptId   String
  callId     String?
  contactId  String?
  campaignId String?
  agentId    String
  isComplete Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  script   Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  agent    User     @relation("AgentScriptResponses", fields: [agentId], references: [id])
  values   ScriptResponseValue[]

  @@index([tenantId])
  @@index([scriptId])
  @@index([callId])
  @@index([agentId])
  @@map("script_responses")
}

model ScriptResponseValue {
  id         String   @id @default(cuid())
  responseId String
  fieldId    String
  value      Json     // string | string[] | number | null
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  response ScriptResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  field    ScriptField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([responseId, fieldId])
  @@index([responseId])
  @@index([fieldId])
  @@map("script_response_values")
}

// ─────────────────────────────────────────
// AgentStatusLog — Historique statuts agents
// ─────────────────────────────────────────

model AgentStatusLog {
  id          String          @id @default(cuid())
  tenantId    String
  agentId     String
  status      AgentStatusType
  startedAt   DateTime        @default(now())
  endedAt     DateTime?
  durationSec Int?
  notes       String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent  User   @relation("AgentStatusLogs", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId, agentId])
  @@index([tenantId, startedAt])
  @@map("agent_status_logs")
}

// ─────────────────────────────────────────
// AgentPlanning — Événements planifiés
// ─────────────────────────────────────────

model AgentPlanning {
  id          String            @id @default(cuid())
  tenantId    String
  agentId     String
  createdById String
  type        PlanningEventType
  title       String
  startAt     DateTime
  endAt       DateTime
  status      PlanningStatus    @default(APPROVED)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent     User   @relation("AgentPlannings", fields: [agentId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PlanningCreator", fields: [createdById], references: [id])

  @@index([tenantId, agentId])
  @@index([tenantId, startAt])
  @@map("agent_planning")
}

// ─────────────────────────────────────────
// AgentPlanningRequest — Demandes agents
// ─────────────────────────────────────────

model AgentPlanningRequest {
  id             String            @id @default(cuid())
  tenantId       String
  agentId        String
  type           PlanningEventType
  title          String
  startAt        DateTime
  endAt          DateTime
  status         PlanningStatus    @default(PENDING)
  motif          String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent      User   @relation("AgentPlanningRequests", fields: [agentId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("PlanningReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@map("agent_planning_requests")
}

// ─────────────────────────────────────────
// IA Analytique — Enums
// ─────────────────────────────────────────

enum AiJobType {
  SUMMARY
  SCORING
  SUGGESTIONS
  PERFORMANCE
}

enum AiJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────
// AiJob — Résultats des analyses IA
// ─────────────────────────────────────────

model AiJob {
  id           String      @id @default(cuid())
  tenantId     String
  userId       String
  type         AiJobType
  status       AiJobStatus @default(PENDING)
  input        Json
  result       Json?
  error        String?
  model        String      @default("llama3")
  processingMs Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("UserAiJobs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([userId])
  @@map("ai_jobs")
}

// ─────────────────────────────────────────
// AiUsage — Quota mensuel par tenant
// ─────────────────────────────────────────

model AiUsage {
  id        String   @id @default(cuid())
  tenantId  String
  month     String   // format "2026-04"
  jobCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month])
  @@map("ai_usage")
}

// ─────────────────────────────────────────
// CampaignCriteria — Critères de qualification RDV par campagne
// ─────────────────────────────────────────

model CampaignCriteria {
  id          String   @id @default(cuid())
  tenantId    String
  campaignId  String   @unique
  name        String   @default("Critères de qualification")
  description String?
  minScoreOk  Int      @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fields   CampaignCriteriaField[]

  @@index([tenantId])
  @@map("campaign_criteria")
}

model CampaignCriteriaField {
  id         String            @id @default(cuid())
  criteriaId String
  label      String
  key        String
  type       CriteriaFieldType
  required   Boolean           @default(false)
  weight     Int               @default(1)
  position   Int               @default(0)
  options    Json?
  validation Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  criteria  CampaignCriteria      @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  responses AppointmentResponse[]

  @@unique([criteriaId, key])
  @@index([criteriaId])
  @@map("campaign_criteria_fields")
}

// ─────────────────────────────────────────
// AppointmentResponse — Réponses aux critères lors d'un RDV
// ─────────────────────────────────────────

model AppointmentResponse {
  id            String   @id @default(cuid())
  tenantId      String
  appointmentId String
  fieldId       String
  value         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment           @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  field       CampaignCriteriaField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, fieldId])
  @@index([tenantId])
  @@index([appointmentId])
  @@map("appointment_responses")
}

// ─────────────────────────────────────────
// AppointmentScore — Score et statut qualification RDV
// ─────────────────────────────────────────

model AppointmentScore {
  id            String                         @id @default(cuid())
  tenantId      String
  appointmentId String                         @unique
  score         Int
  maxScore      Int
  percentage    Float
  status        AppointmentQualificationStatus @default(PENDING)
  details       Json?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("ScoreReviewer", fields: [reviewedById], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("appointment_scores")
}

// ─────────────────────────────────────────
// Internal Chat — Messagerie interne équipe
// ─────────────────────────────────────────

model InternalChannel {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User              @relation("ChannelCreator", fields: [createdById], references: [id])
  messages  InternalMessage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("internal_channels")
}

model InternalMessage {
  id        String   @id @default(cuid())
  tenantId  String
  channelId String
  userId    String
  content   String   @db.Text
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel InternalChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User            @relation("UserMessages", fields: [userId], references: [id])

  @@index([tenantId, channelId])
  @@index([channelId, createdAt])
  @@map("internal_messages")
}

// ─────────────────────────────────────────
// Quality — Enums
// ─────────────────────────────────────────

enum QualityActionType {
  FORMATION
  DEBRIEF
  RECADRAGE
}

enum HrRequestType {
  ABSENCE
  FORMATION
  CONGE
}

enum HrRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────
// QualityGrid — Grille qualité configurable par campagne
// ─────────────────────────────────────────

model QualityGrid {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String?
  name       String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign    Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  items       QualityGridItem[]
  evaluations QualityEvaluation[]

  @@index([tenantId])
  @@index([tenantId, campaignId])
  @@map("quality_grids")
}

model QualityGridItem {
  id         String  @id @default(cuid())
  gridId     String
  name       String
  weight     Float   @default(1.0)
  maxScore   Int     @default(5)
  isRequired Boolean @default(false)
  position   Int     @default(0)

  grid      QualityGrid           @relation(fields: [gridId], references: [id], onDelete: Cascade)
  evalItems QualityEvalItem[]

  @@index([gridId])
  @@map("quality_grid_items")
}

// ─────────────────────────────────────────
// QualityEvaluation — Évaluation d'un appel
// ─────────────────────────────────────────

model QualityEvaluation {
  id          String   @id @default(cuid())
  tenantId    String
  callLogId   String
  agentId     String
  evaluatorId String
  gridId      String
  score       Float
  maxScore    Float
  percentage  Float
  comment     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callLog   CallLog           @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  agent     User              @relation("EvaluatedAgent", fields: [agentId], references: [id])
  evaluator User              @relation("Evaluator", fields: [evaluatorId], references: [id])
  grid      QualityGrid       @relation(fields: [gridId], references: [id])
  items     QualityEvalItem[]
  actions   QualityAction[]

  @@unique([callLogId, evaluatorId])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, createdAt])
  @@map("quality_evaluations")
}

model QualityEvalItem {
  id           String  @id @default(cuid())
  evaluationId String
  gridItemId   String
  score        Int
  comment      String?

  evaluation QualityEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  gridItem   QualityGridItem   @relation(fields: [gridItemId], references: [id])

  @@unique([evaluationId, gridItemId])
  @@map("quality_eval_items")
}

// ─────────────────────────────────────────
// AppointmentQualification — Qualification RDV par QA
// ─────────────────────────────────────────

model AppointmentQualification {
  id              String                         @id @default(cuid())
  tenantId        String
  appointmentId   String                         @unique
  qualifiedById   String
  status          AppointmentQualificationStatus
  qualityScore    Int?
  comment         String?                        @db.Text
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  qualifiedBy User        @relation("QualifiedBy", fields: [qualifiedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, qualifiedById])
  @@map("appointment_qualifications")
}

// ─────────────────────────────────────────
// QualityAction — Actions correctives
// ─────────────────────────────────────────

model QualityAction {
  id           String            @id @default(cuid())
  tenantId     String
  agentId      String
  createdById  String
  evaluationId String?
  type         QualityActionType
  comment      String            @db.Text
  createdAt    DateTime          @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent      User               @relation("ActionTarget", fields: [agentId], references: [id])
  createdBy  User               @relation("ActionCreator", fields: [createdById], references: [id])
  evaluation QualityEvaluation? @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@map("quality_actions")
}

// ─────────────────────────────────────────
// HrRequest — Demandes d'absence / formation / congé
// ─────────────────────────────────────────

model HrRequest {
  id             String          @id @default(cuid())
  tenantId       String
  agentId        String
  type           HrRequestType
  startDate      DateTime
  endDate        DateTime
  comment        String?         @db.Text
  status         HrRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewComment  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent      User    @relation("HrRequestAgent", fields: [agentId], references: [id])
  reviewedBy User?   @relation("HrReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
  @@map("hr_requests")
}

// ─────────────────────────────────────────
// HrAttendance — Suivi présence journalier
// ─────────────────────────────────────────

model HrAttendance {
  id               String   @id @default(cuid())
  tenantId         String
  agentId          String
  date             DateTime @db.Date
  hoursWorked      Float    @default(0)
  minutesProductive Int     @default(0)
  isPresent        Boolean  @default(true)
  notes            String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent  User   @relation("AttendanceAgent", fields: [agentId], references: [id])

  @@unique([tenantId, agentId, date])
  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([tenantId, date])
  @@map("hr_attendance")
}

// ─────────────────────────────────────────
// CallSupervisionLog — Écoute / Whisper superviseur
// ─────────────────────────────────────────

enum SupervisionAction {
  LISTEN
  WHISPER
  BARGE
  STOP
}

model CallSupervisionLog {
  id           String            @id @default(cuid())
  tenantId     String
  supervisorId String
  agentId      String
  callId       String?
  action       SupervisionAction
  channel      String?
  startedAt    DateTime          @default(now())
  endedAt      DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supervisor User   @relation("SupervisionSupervisor", fields: [supervisorId], references: [id])
  agent      User   @relation("SupervisionAgent", fields: [agentId], references: [id])

  @@index([tenantId])
  @@index([tenantId, supervisorId])
  @@index([tenantId, agentId])
  @@map("call_supervision_logs")
}
